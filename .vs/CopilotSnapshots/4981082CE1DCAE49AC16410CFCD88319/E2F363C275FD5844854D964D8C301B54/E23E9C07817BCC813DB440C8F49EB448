*{box-sizing:border-box;font-family:Arial,Helvetica,sans-serif}
body{margin:0;background:#f7f7f7;color:#222}
header{background:#2c3e50;color:#fff;padding:12px 20px}
main{display:flex;gap:12px;padding:12px}
.panel{width:320px;background:#fff;padding:12px;border-radius:6px;box-shadow:0 2px 6px rgba(0,0,0,.08)}
.panel label{display:block;margin:8px 0}
.panel input, .panel select{width:100%;padding:6px;margin-top:4px}
.panel .buttons{display:flex;gap:8px;margin-top:8px}
#canvas{ }
#canvas{ }
.canvas{flex:1;background:#fff;border-radius:6px;padding:12px;overflow:auto;position:relative;min-height:500px}
/* make the drawing surface large by default so it can be scrolled/panned */
#svgCanvas{position:absolute;left:12px;top:12px;width:2000px;height:1500px;z-index:0}
.personNode{fill:#ecf0f1;stroke:#34495e;stroke-width:1.5}
.personText{font-size:12px;pointer-events:none}
.link{stroke:#7f8c8d;stroke-width:2;fill:none}
.marriage{stroke:#c0392b;stroke-width:2}
.peopleItem{padding:6px;border-bottom:1px solid #eee;display:flex;justify-content:space-between}
.peopleItem button{margin-left:6px}

/* Card layout */
.cardsContainer-placeholder{ }
.cardsContainer-placeholder{ }
#cardsContainer{position:absolute;left:12px;top:12px;width:2000px;height:1500px;z-index:1}
.card{position:absolute;width:180px;background:#fff;border:1px solid #ccc;border-radius:8px;padding:8px;box-shadow:0 2px 6px rgba(0,0,0,.1);cursor:move}
.card h3{margin:0 0 6px 0;font-size:14px}
.card p{margin:2px 0;font-size:12px}
.card .cardActions{display:flex;gap:6px;margin-top:6px}
.card .smallBtn{padding:4px 6px;font-size:12px}

/* Context menu */
.context-menu{position:absolute;background:#fff;border:1px solid #ccc;padding:6px;border-radius:4px;box-shadow:0 2px 6px rgba(0,0,0,.12);z-index:2}
.context-menu button{background:none;border:0;padding:6px 10px;display:block;width:100%;text-align:left}
.card .editor{margin-top:8px;border-top:1px dashed #eee;padding-top:8px}
.card .editor label{display:block;margin:6px 0}
.card .editor input, .card .editor select{width:100%;padding:4px}

/* modal */
.modal-overlay{position:fixed;left:0;top:0;right:0;bottom:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:10000}
.modal{background:#fff;padding:0;border-radius:8px;min-width:320px;box-shadow:0 8px 24px rgba(0,0,0,.3);position:fixed}
.modal .modal-header{display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-bottom:1px solid #eee;cursor:move}
.modal .modal-body{padding:12px}
.modal h3{margin:0;font-size:16px}
.modal .closeBtn{background:none;border:0;font-size:18px;line-height:1;color:#333;cursor:pointer}
.parent-link{stroke:#2980b9;stroke-width:2}