// Simple family tree app (no backend) - stores data in localStorage
const STORAGE_KEY = 'familyTree_v1'
let data = { people: [] }

// DOM
const form = document.getElementById('personForm')
const peopleList = document.getElementById('peopleList')
const svg = document.getElementById('svgCanvas')
const cardsContainer = document.getElementById('cardsContainer')
const canvasEl = document.querySelector('.canvas')
const parentsSelect = document.getElementById('parents')
const spouseSelect = document.getElementById('spouse')
const resetBtn = document.getElementById('resetBtn')

function load(){
  try{ data = JSON.parse(localStorage.getItem(STORAGE_KEY)) || {people:[]}}catch(e){data={people:[]}}
}

function save(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(data)) }

function uid(){ return Math.random().toString(36).slice(2,9) }

// escape HTML for safe insertion
function escapeHtml(str){
  return String(str||'').replace(/[&<>"']/g, function(s){
    return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"})[s]
  })
}

function renderList(){
  peopleList.innerHTML = ''
  data.people.forEach(p=>{
    const li = document.createElement('li')
    li.className = 'peopleItem'
    const title = document.createElement('div')
    title.textContent = `${p.firstName} ${p.lastName || ''} (${p.age||''})`
    const actions = document.createElement('div')
    const edit = document.createElement('button')
    edit.textContent = 'Изменить'
    edit.onclick = ()=> loadToForm(p.id)
    const del = document.createElement('button')
    del.textContent = 'Удалить'
    del.onclick = ()=>{ if(confirm('Удалить персонажа?')){ deletePerson(p.id) } }
    actions.appendChild(edit); actions.appendChild(del)
    li.appendChild(title); li.appendChild(actions)
    peopleList.appendChild(li)
  })
  refreshSelects()
}

function refreshSelects(){
  parentsSelect.innerHTML = ''
  spouseSelect.innerHTML = '<option value="">-- нет --</option>'
  data.people.forEach(p=>{
    const opt = document.createElement('option')
    opt.value = p.id
    opt.textContent = `${p.firstName} ${p.lastName||''}`
    parentsSelect.appendChild(opt)
    const opt2 = opt.cloneNode(true)
    spouseSelect.appendChild(opt2)
  })
}

function loadToForm(id){
  const p = data.people.find(x=>x.id===id)
  if(!p) return
  form.personId.value = p.id
  form.firstName.value = p.firstName
  form.lastName.value = p.lastName
  form.age.value = p.age
  Array.from(parentsSelect.options).forEach(o=> o.selected = p.parents && p.parents.includes(o.value))
  spouseSelect.value = p.spouse || ''
}

form.addEventListener('submit', e=>{
  e.preventDefault()
  const id = form.personId.value || uid()
  const person = {
    id,
    firstName: form.firstName.value.trim(),
    lastName: form.lastName.value.trim(),
    age: form.age.value ? Number(form.age.value) : null,
    parents: Array.from(parentsSelect.selectedOptions).map(o=>o.value),
    spouse: spouseSelect.value || null
  }
  const existing = data.people.find(p=>p.id===id)
  if(existing){
    Object.assign(existing, person)
  }else{
    data.people.push(person)
  }
  // ensure parents have this child? we'll store only parents in child node; spouse stored on child; keep simple
  save();
  renderAll()
  form.reset()
  form.personId.value = ''
})

resetBtn.addEventListener('click', ()=>{ form.reset(); form.personId.value = '' })

function deletePerson(id){
  data.people = data.people.filter(p=>p.id!==id)
  // remove references
  data.people.forEach(p=>{
    if(p.spouse===id) p.spouse = null
    if(p.parents) p.parents = p.parents.filter(x=>x!==id)
  })
  save(); renderAll()
}

function buildRelationships(){
  const map = new Map(data.people.map(p=>[p.id, p]))
  // children list
  data.people.forEach(p=> p.children = [])
  data.people.forEach(p=>{
    (p.parents||[]).forEach(pid=>{
      const par = map.get(pid)
      if(par) par.children.push(p.id)
    })
  })
}

function renderGraph(){
  // Render draggable HTML cards and draw SVG lines between them
  svg.innerHTML = ''
  cardsContainer.innerHTML = ''
  if(data.people.length===0) return
  buildRelationships()

  // ensure every person has position (persisted in person.pos)
  const containerRect = cardsContainer.getBoundingClientRect()
  data.people.forEach((p,i)=>{
    if(!p.pos) p.pos = { x: 20 + (i%4)*220, y: 20 + Math.floor(i/4)*160 }
  })

  // helper to draw a line element
  function drawLine(x1,y1,x2,y2,cls){
    const line = document.createElementNS('http://www.w3.org/2000/svg','line')
    line.setAttribute('x1', x1)
    line.setAttribute('y1', y1)
    line.setAttribute('x2', x2)
    line.setAttribute('y2', y2)
    line.classList.add('link')
    if(cls) line.classList.add(cls)
    svg.appendChild(line)
  }

  // draw parent->child and marriage lines based on card centers
  const personById = new Map(data.people.map(p=>[p.id,p]))
  // create cards first with inline editor and pointer drag
  data.people.forEach(p=>{
    const c = document.createElement('div')
    c.className = 'card'
    c.style.left = p.pos.x + 'px'
    c.style.top = p.pos.y + 'px'
    c.dataset.id = p.id
    c.innerHTML = `<h3>${escapeHtml(p.firstName)} ${escapeHtml(p.lastName||'')}</h3>
      <p>Возраст: ${p.age||''}</p>
      <div class="cardActions">
        <button class="smallBtn" data-action="toggleEditor">Опции</button>
        <button class="smallBtn" data-action="delete">Удалить</button>
      </div>
      <div class="editor" style="display:none">
        <label>Имя <input name="firstName" value="${escapeHtml(p.firstName)}"></label>
        <label>Фамилия <input name="lastName" value="${escapeHtml(p.lastName||'')}"></label>
        <label>Возраст <input name="age" type="number" value="${p.age||''}"></label>
        <label>Супруг
          <select name="spouse"><option value="">-- нет --</option></select>
        </label>
        <label>Родители (Ctrl/Command)
          <select name="parents" multiple size="4"></select>
        </label>
        <div style="display:flex;gap:6px;margin-top:6px">
          <button class="smallBtn" data-action="saveCard">Сохранить</button>
          <button class="smallBtn" data-action="cancelEdit">Отмена</button>
        </div>
      </div>`
    cardsContainer.appendChild(c)

    // populate spouse and parents selects inside editor
    const spouseSel = c.querySelector('select[name="spouse"]')
    const parentsSel = c.querySelector('select[name="parents"]')
    data.people.forEach(pp=>{
      if(pp.id===p.id) return
      const o = document.createElement('option')
      o.value = pp.id; o.textContent = `${pp.firstName} ${pp.lastName||''}`
      spouseSel.appendChild(o)
      const o2 = o.cloneNode(true)
      parentsSel.appendChild(o2)
    })
    spouseSel.value = p.spouse || ''
    Array.from(parentsSel.options).forEach(o=> o.selected = p.parents && p.parents.includes(o.value))


    // pointer drag (per-card) - ignore pointerdown when interacting with controls inside the card
    c.style.touchAction = 'none'
    c.addEventListener('pointerdown', (ev)=>{
      // if clicking a button/input/select inside card, do not start drag
      if(ev.target.closest('button') || ev.target.closest('input') || ev.target.closest('select') || ev.target.closest('.editor')) return
      c.setPointerCapture(ev.pointerId)
      const startX = ev.clientX, startY = ev.clientY
      const origX = p.pos.x, origY = p.pos.y
      function moveHandler(me){
        const dx = me.clientX - startX, dy = me.clientY - startY
        p.pos.x = Math.max(0, origX + dx); p.pos.y = Math.max(0, origY + dy)
        c.style.left = p.pos.x + 'px'; c.style.top = p.pos.y + 'px'
        redrawLines()
      }
      function upHandler(){
        try{ c.releasePointerCapture(ev.pointerId) }catch(e){}
        window.removeEventListener('pointermove', moveHandler)
        window.removeEventListener('pointerup', upHandler)
        save()
      }
      window.addEventListener('pointermove', moveHandler)
      window.addEventListener('pointerup', upHandler)
    })
  })

  function getCenter(id){
    const p = personById.get(id) || data.people.find(x=>x.id===id)
    if(!p || !p.pos) return null
    return { x: p.pos.x + 90, y: p.pos.y + 24 }
  }

  function redrawLines(){
    svg.innerHTML = ''
    // marriages (draw once)
    data.people.forEach(p=>{
      if(p.spouse && p.id < p.spouse){
        const a = getCenter(p.id), b = getCenter(p.spouse)
        if(a && b) drawLine(a.x,a.y,b.x,b.y,'marriage')
      }
    })
    // parent-parent links (co-parents for same child)
    const drawnPairs = new Set()
    data.people.forEach(child=>{
      const parents = child.parents||[]
      for(let i=0;i<parents.length;i++){
        for(let j=i+1;j<parents.length;j++){
          const aId = parents[i], bId = parents[j]
          const key = aId<bId?`${aId}_${bId}`:`${bId}_${aId}`
          if(drawnPairs.has(key)) continue
          drawnPairs.add(key)
          const a = getCenter(aId), b = getCenter(bId)
          if(a && b) drawLine(a.x, a.y, b.x, b.y, 'parent-link')
        }
      }
    })
    // parent -> child
    data.people.forEach(p=>{
      (p.parents||[]).forEach(pid=>{
        const a = getCenter(pid), b = getCenter(p.id)
        if(a && b) drawLine(a.x, a.y+20, b.x, b.y-20)
      })
    })
  }

  // initial draw
  redrawLines()
}

// delegated click handler for card actions
cardsContainer.addEventListener('click', (ev)=>{
  const btn = ev.target.closest('button')
  if(!btn) return
  const card = ev.target.closest('.card')
  if(!card) return
  const id = card.dataset.id
  const person = data.people.find(p=>p.id===id)
  if(!person) return
  const action = btn.dataset.action
  if(action === 'toggleEditor'){
    const ed = card.querySelector('.editor')
    ed.style.display = ed.style.display === 'none' ? 'block' : 'none'
  } else if(action === 'delete'){
    if(confirm('Удалить персонажа?')) deletePerson(id)
  } else if(action === 'cancelEdit'){
    const ed = card.querySelector('.editor')
    ed.style.display = 'none'
  } else if(action === 'saveCard'){
    const ed = card.querySelector('.editor')
    const fn = ed.querySelector('input[name="firstName"]').value.trim()
    const ln = ed.querySelector('input[name="lastName"]').value.trim()
    const ageV = ed.querySelector('input[name="age"]').value
    const spv = ed.querySelector('select[name="spouse"]').value || null
    const parentsV = Array.from(ed.querySelector('select[name="parents"]').selectedOptions).map(o=>o.value)
    person.firstName = fn; person.lastName = ln; person.age = ageV?Number(ageV):null; person.spouse = spv; person.parents = parentsV
    save(); renderAll()
  }
})

// Context menu: create new person on right click
cardsContainer.addEventListener('contextmenu', (ev)=>{
  ev.preventDefault()
  // remove existing menus
  document.querySelectorAll('.context-menu').forEach(n=>n.remove())
  const menu = document.createElement('div')
  menu.className = 'context-menu'
  menu.style.left = ev.clientX + 'px'
  menu.style.top = ev.clientY + 'px'
  menu.innerHTML = '<button data-action="new">Создать нового персонажа здесь</button>'
  document.body.appendChild(menu)
  menu.querySelector('[data-action="new"]').addEventListener('click', ()=>{
    const id = uid()
    const pos = { x: ev.offsetX - 90, y: ev.offsetY - 24 }
    const person = { id, firstName: 'Новый', lastName: '', age:null, parents:[], spouse:null, pos }
    data.people.push(person)
    save(); renderAll()
    menu.remove()
  })
  window.addEventListener('click', ()=> menu.remove(), { once:true })
})

function renderAll(){ renderList(); renderGraph() }

load(); renderAll()

