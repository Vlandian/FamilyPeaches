  data.people.push({id:uid(), firstName:'Иван', lastName:'Иванов', age:60, parents:[], spouse:null})
  data.people.push({id:uid(), firstName:'Мария', lastName:'Иванова', age:58, parents:[], spouse:null})
  data.people.push({id:uid(), firstName:'Ольга', lastName:'Иванова', age:30, parents:[], spouse:null})
  save(); load(); renderAll()
}